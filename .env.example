# Copy to `.env.development` (dev) or `.env` (build) and adjust.

# Base URL the SPA calls. In dev this is a relative path proxied to the backend
# (see vite.config.js server.proxy). For a deployed build, set the absolute URL,
# e.g. https://aitt-backend.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# "true"  -> run entirely on in-memory mock data, no backend needed (offline demo).
# "false" -> talk to the real backend at VITE_API_BASE_URL (default).
VITE_USE_MOCK=false
